[
  {
    "name": "Flight Delay Protection",
    "category": "FLIGHT_DELAY",
    "description": "Get automatic payout when your flight is delayed beyond your chosen threshold or cancelled.",
    "short_description": "Automatic payout for flight delays and cancellations.",
    "base_payout": 500.00,
    "min_duration_days": 1,
    "max_duration_days": 7,
    "risk_margin": 0.25,
    "parameters_schema": {
      "fields": [
        {
          "name": "airline_code",
          "type": "select",
          "label": "Airline",
          "required": true,
          "options": [
            {"value": "VN", "label": "Vietnam Airlines"}
          ]
        },
        {
          "name": "flight_number",
          "type": "string",
          "label": "Flight Number",
          "required": true,
          "placeholder": "e.g., VN123"
        },
        {
          "name": "departure_date",
          "type": "date",
          "label": "Departure Date",
          "required": true
        },
        {
          "name": "delay_threshold_minutes",
          "type": "number",
          "label": "Bồi thường khi trễ hơn bao nhiêu phút?",
          "required": true,
          "default": 120,
          "min": 60,
          "max": 360,
          "step": 30
        },
        {
          "name": "duration_days",
          "type": "number",
          "label": "Thời hạn bảo hiểm (ngày)",
          "required": true,
          "default": 3,
          "min": 1,
          "max": 7,
          "step": 1
        }
      ]
    },
    "trigger_conditions": {
      "type": "PARAMETRIC",
      "api_source": "aviation",
      "rules": [
        {
          "field": "delay_minutes",
          "operator": ">=",
          "threshold_param": "delay_threshold_minutes",
          "payout_multiplier": 1.0
        },
        {
          "field": "status",
          "operator": "==",
          "value": "CANCELLED",
          "payout_multiplier": 1.5
        }
      ]
    }
  },
  {
    "name": "Weather Insurance",
    "category": "CROP_WEATHER",
    "description": "Get automatic payout when weather conditions at your location exceed your chosen threshold. Powered by real-time OpenWeatherMap data.",
    "short_description": "Real-time weather-triggered parametric insurance.",
    "base_payout": 1000.00,
    "min_duration_days": 30,
    "max_duration_days": 180,
    "risk_margin": 0.30,
    "parameters_schema": {
      "fields": [
        {
          "name": "location_name",
          "type": "city_select",
          "label": "Địa điểm",
          "required": true,
          "options": [
            {"value": "Hanoi",            "label": "Hà Nội",           "lat": 21.0285, "lon": 105.8542},
            {"value": "Ho Chi Minh City", "label": "TP. Hồ Chí Minh", "lat": 10.8231, "lon": 106.6297},
            {"value": "Da Nang",          "label": "Đà Nẵng",          "lat": 16.0471, "lon": 108.2062},
            {"value": "Can Tho",          "label": "Cần Thơ",          "lat": 10.0341, "lon": 105.7878},
            {"value": "Hue",              "label": "Huế",              "lat": 16.4637, "lon": 107.5909},
            {"value": "Hai Phong",        "label": "Hải Phòng",        "lat": 20.8449, "lon": 106.6881},
            {"value": "Nha Trang",        "label": "Nha Trang",        "lat": 12.2388, "lon": 109.1967},
            {"value": "Da Lat",           "label": "Đà Lạt",           "lat": 11.9465, "lon": 108.4419},
            {"value": "Vung Tau",         "label": "Vũng Tàu",         "lat": 10.3460, "lon": 107.0843},
            {"value": "Vinh",             "label": "Vinh",             "lat": 18.6699, "lon": 105.6821}
          ]
        },
        {
          "name": "weather_metric",
          "type": "select",
          "label": "Chỉ số thời tiết muốn bảo vệ",
          "required": true,
          "options": [
            {"value": "rainfall_mm", "label": "Lượng mưa (mm)"},
            {"value": "temp_celsius", "label": "Nhiệt độ (°C)"}
          ]
        },
        {
          "name": "threshold",
          "type": "number",
          "label": "Giá trị ngưỡng bồi thường",
          "required": true
        },
        {
          "name": "comparison",
          "type": "select",
          "label": "Bồi thường khi chỉ số",
          "required": true,
          "options": [
            {"value": "ABOVE", "label": "Vượt quá ngưỡng trên"},
            {"value": "BELOW", "label": "Thấp hơn ngưỡng trên"}
          ]
        },
        {
          "name": "duration_days",
          "type": "number",
          "label": "Thời hạn bảo hiểm (ngày)",
          "required": true,
          "default": 30,
          "min": 30,
          "max": 180,
          "step": 30
        }
      ]
    },
    "trigger_conditions": {
      "type": "PARAMETRIC",
      "api_source": "openweathermap",
      "check_interval_hours": 6,
      "rules": [
        {
          "field": "{weather_metric}",
          "operator": "{comparison}",
          "threshold_param": "threshold",
          "payout_multiplier": 1.0
        }
      ]
    }
  }
]
